      },
      "html": "\n<div class=\"aero-root relative min-h-screen w-full flex items-center justify-center overflow-hidden bg-[#010B13]\" data-kid=\"0\">\n    \n    <div class=\"absolute inset-0 z-0 overflow-hidden pointer-events-none\" data-kid=\"1\">\n        <div class=\"orb-indigo absolute -top-1/4 -left-1/4 w-[80%] h-[80%] rounded-full bg-[#6F00FF]/30 blur-[120px]\" data-kid=\"2\"></div>\n        <div class=\"orb-cyan absolute top-1/2 -right-1/4 w-[60%] h-[60%] rounded-full bg-[#0FFFFF]/20 blur-[140px]\" data-kid=\"3\"></div>\n        <div class=\"orb-violet absolute -bottom-1/4 left-1/4 w-[70%] h-[70%] rounded-full bg-[#8F00FF]/25 blur-[130px]\" data-kid=\"4\"></div>\n    </div>\n\n    \n    <div class=\"fixed top-8 right-8 z-50\" data-kid=\"5\">\n        <div class=\"theme-toggle-container bg-white/5 backdrop-blur-xl border border-white/10 rounded-full p-1.5 flex items-center gap-2 shadow-2xl\" data-kid=\"6\">\n            <button id=\"theme-btn\" class=\"relative w-14 h-8 rounded-full bg-white/5 border border-white/10 cursor-pointer overflow-hidden group\" data-kid=\"7\">\n                <div id=\"toggle-indicator\" class=\"absolute top-1 left-1 w-6 h-6 rounded-full bg-white shadow-lg shadow-white/20 transition-all duration-300\" data-kid=\"8\"></div>\n                <div class=\"flex justify-between items-center px-2 h-full\" data-kid=\"9\">\n                    <i data-lucide=\"sun\" class=\"w-3.5 h-3.5 text-white/50 z-10\" data-kid=\"10\"></i>\n                    <i data-lucide=\"moon\" class=\"w-3.5 h-3.5 text-white/50 z-10\" data-kid=\"11\"></i>\n                </div>\n            </button>\n        </div>\n    </div>\n\n    \n    <main class=\"relative z-10 w-full max-w-5xl px-6 py-12\" data-kid=\"12\">\n        <div id=\"login-card\" class=\"frosted-panel overflow-hidden rounded-[48px] border border-white/10 bg-white/5 backdrop-blur-3xl shadow-[0_32px_128px_-16px_rgba(0,0,0,0.6)] flex flex-col lg:flex-row opacity-0 translate-y-8\" data-kid=\"13\">\n            \n            \n            <div class=\"lg:w-[45%] bg-gradient-to-br from-[#6F00FF]/15 via-transparent to-[#0FFFFF]/15 p-12 flex flex-col items-center justify-center relative border-b lg:border-b-0 lg:border-r border-white/10 overflow-hidden\" data-kid=\"14\">\n                \n                <div class=\"absolute inset-0 opacity-30\" data-kid=\"15\">\n                    <svg class=\"w-full h-full\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" data-kid=\"16\">\n                        <defs data-kid=\"17\">\n                            <pattern id=\"grid\" width=\"8\" height=\"8\" patternUnits=\"userSpaceOnUse\" data-kid=\"18\">\n                                <path d=\"M 8 0 L 0 0 0 8\" fill=\"none\" stroke=\"white\" stroke-width=\"0.05\" data-kid=\"19\"></path>\n                                <circle cx=\"0\" cy=\"0\" r=\"0.1\" fill=\"white\" data-kid=\"20\"></circle>\n                            </pattern>\n                        </defs>\n                        <rect width=\"100\" height=\"100\" fill=\"url(#grid)\" data-kid=\"21\"></rect>\n                    </svg>\n                </div>\n                \n                <div class=\"relative z-10 w-full max-w-[340px] aspect-square flex items-center justify-center\" data-kid=\"22\">\n                    \n                    <svg viewBox=\"0 0 200 200\" class=\"w-full h-full filter drop-shadow-[0_10px_60px_rgba(111,0,255,0.5)]\" data-kid=\"23\">\n                        <defs data-kid=\"24\">\n                            <linearGradient id=\"liquid-gradient\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\" data-kid=\"25\">\n                                <stop offset=\"0%\" style=\"stop-color:#6F00FF\" data-kid=\"26\"></stop>\n                                <stop offset=\"100%\" style=\"stop-color:#0FFFFF\" data-kid=\"27\"></stop>\n                            </linearGradient>\n                        </defs>\n                        \n                        <path id=\"morph-path\" fill=\"url(#liquid-gradient)\" d=\"M160,100c0,33.1-26.9,60-60,60s-60-26.9-60-60c0-33.1,26.9-60,60-60S160,66.9,160,100z\" data-kid=\"28\"></path>\n                    </svg>\n                    \n                    \n                    <svg class=\"hidden\" data-kid=\"29\">\n                        <path id=\"target-path\" d=\"M160,60 L160,140 C160,151 151,160 140,160 L60,160 C49,160 40,151 40,140 L40,60 C40,49 49,40 60,40 L140,40 C151,40 160,49 160,60 Z\" data-kid=\"30\"></path>\n                    </svg>\n                </div>\n                \n                <div class=\"mt-12 text-center relative z-10\" data-kid=\"31\">\n                    <h2 class=\"text-white text-2xl font-bold font-[Plus_Jakarta_Sans] tracking-tight mb-3\" data-kid=\"32\">AKESP Timetable</h2>\n                    <p class=\"text-white/50 text-sm font-[Inter] max-w-[240px]\" data-kid=\"33\">Experience the future of academic management with our Aero system.</p>\n                </div>\n            </div>\n\n            \n            <div class=\"lg:w-[55%] p-10 lg:p-20 flex flex-col justify-center bg-black/20\" data-kid=\"34\">\n                <div class=\"form-content\" data-kid=\"35\">\n                    <header class=\"mb-12\" data-kid=\"36\">\n                        <span class=\"header-animate inline-block px-3 py-1 rounded-full bg-[#0FFFFF]/10 text-[#0FFFFF] text-[10px] font-bold uppercase tracking-widest mb-5 border border-[#0FFFFF]/20\" data-kid=\"37\">Aero v1.0</span>\n                        <h1 class=\"header-animate text-5xl font-extrabold text-white font-[Plus_Jakarta_Sans] mb-4 tracking-tight\" data-kid=\"38\">Sign In</h1>\n                        <p class=\"header-animate text-white/60 font-[Inter] text-lg\" data-kid=\"39\">Access your dashboard</p>\n                    </header>\n\n                    <form class=\"space-y-6\" data-kid=\"40\">\n                        <div class=\"space-y-2 form-group\" data-kid=\"41\">\n                            <label class=\"text-xs font-bold text-white/40 uppercase tracking-widest ml-1\" data-kid=\"42\">Email</label>\n                            <div class=\"relative group\" data-kid=\"43\">\n                                <div class=\"absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none\" data-kid=\"44\">\n                                    <i data-lucide=\"mail\" class=\"w-4 h-4 text-white/20 group-focus-within:text-[#0FFFFF] transition-colors\" data-kid=\"45\"></i>\n                                </div>\n                                <input type=\"email\" placeholder=\"alex@akesp.edu\" class=\"w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-12 pr-4 text-white placeholder-white/20 focus:outline-hidden focus:border-[#0FFFFF]/40 focus:ring-4 focus:ring-[#0FFFFF]/5 transition-all font-[Inter]\" data-kid=\"46\">\n                            </div>\n                        </div>\n\n                        <div class=\"space-y-2 form-group\" data-kid=\"47\">\n                            <label class=\"text-xs font-bold text-white/40 uppercase tracking-widest ml-1\" data-kid=\"48\">Password</label>\n                            <div class=\"relative group\" data-kid=\"49\">\n                                <div class=\"absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none\" data-kid=\"50\">\n                                    <i data-lucide=\"lock\" class=\"w-4 h-4 text-white/20 group-focus-within:text-[#0FFFFF] transition-colors\" data-kid=\"51\"></i>\n                                </div>\n                                <input type=\"password\" placeholder=\"••••••••\" class=\"w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-12 pr-12 text-white placeholder-white/20 focus:outline-hidden focus:border-[#0FFFFF]/40 focus:ring-4 focus:ring-[#0FFFFF]/5 transition-all font-[Inter]\" data-kid=\"52\">\n                                <button type=\"button\" class=\"absolute inset-y-0 right-0 pr-4 flex items-center text-white/20 hover:text-white/60\" data-kid=\"53\">\n                                    <i data-lucide=\"eye\" class=\"w-4 h-4\" data-kid=\"54\"></i>\n                                </button>\n                            </div>\n                        </div>\n\n                        <div class=\"flex items-center justify-between text-sm py-2 form-group\" data-kid=\"55\">\n                            <label class=\"flex items-center gap-3 cursor-pointer group\" data-kid=\"56\">\n                                <div class=\"relative\" data-kid=\"57\">\n                                    <input type=\"checkbox\" class=\"sr-only peer\" data-kid=\"58\">\n                                    <div class=\"w-5 h-5 rounded-lg border border-white/10 bg-white/5 peer-checked:bg-[#6F00FF] peer-checked:border-[#6F00FF] transition-all flex items-center justify-center\" data-kid=\"59\">\n                                        <i data-lucide=\"check\" class=\"w-3 h-3 text-white hidden peer-checked:block\" data-kid=\"60\"></i>\n                                    </div>\n                                </div>\n                                <span class=\"text-white/60 group-hover:text-white/90 transition-colors font-[Inter]\" data-kid=\"61\">Keep me signed in</span>\n                            </label>\n                            <a href=\"#\" class=\"text-[#0FFFFF] hover:text-[#0FFFFF]/80 font-semibold transition-colors font-[Inter]\" data-kid=\"62\">Reset Access?</a>\n                        </div>\n\n                        <button type=\"button\" id=\"submit-btn\" class=\"w-full bg-gradient-to-r from-[#6F00FF] to-[#8F00FF] hover:from-[#7c1aff] hover:to-[#9a1aff] text-white font-bold py-4 rounded-2xl shadow-[0_20px_40px_-12px_rgba(111,0,255,0.4)] transform transition-transform active:scale-[0.98] mt-4 font-[Plus_Jakarta_Sans] tracking-wide relative overflow-hidden group\" data-kid=\"63\">\n                            <span class=\"relative z-10 flex items-center justify-center gap-2\" data-kid=\"64\">\n                                Enter Dashboard\n                                <i data-lucide=\"arrow-right\" class=\"w-4 h-4 group-hover:translate-x-1 transition-transform\" data-kid=\"65\"></i>\n                            </span>\n                            <div class=\"absolute inset-0 bg-white/10 translate-x-[-100%] group-hover:translate-x-0 transition-transform duration-500 skew-x-12\" data-kid=\"66\"></div>\n                        </button>\n                    </form>\n\n                    <footer class=\"mt-12 flex items-center gap-6 pt-8 border-t border-white/10 form-group\" data-kid=\"67\">\n                        <p class=\"text-white/40 text-[10px] font-bold font-[Inter] uppercase tracking-[0.2em]\" data-kid=\"68\">Social Access</p>\n                        <div class=\"flex gap-3\" data-kid=\"69\">\n                            <button class=\"w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:bg-white/10 transition-all cursor-pointer\" data-kid=\"70\">\n                                <i data-lucide=\"github\" class=\"w-5 h-5\" data-kid=\"71\"></i>\n                            </button>\n                            <button class=\"w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:bg-white/10 transition-all cursor-pointer\" data-kid=\"72\">\n                                <i data-lucide=\"twitter\" class=\"w-5 h-5\" data-kid=\"73\"></i>\n                            </button>\n                        </div>\n                    </footer>\n                </div>\n            </div>\n        </div>\n    </main>\n\n    \n    <div class=\"pointer-events-none absolute inset-0 z-0 opacity-10\" data-kid=\"74\">\n        <div class=\"absolute top-10 left-10 w-32 h-32 border border-white/20 rounded-full blur-2xl\" data-kid=\"75\"></div>\n        <div class=\"absolute bottom-20 right-20 w-48 h-48 border border-[#0FFFFF]/20 rounded-full blur-3xl\" data-kid=\"76\"></div>\n    </div>\n</div>\n\n<style data-kid=\"77\">\n@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap');\n\nbody {\n    background-color: #010B13;\n    margin: 0;\n    padding: 0;\n}\n\n.frosted-panel {\n    position: relative;\n    overflow: hidden;\n}\n\n/* Custom glowing borders */\n.frosted-panel::before {\n    content: '';\n    position: absolute;\n    inset: 0;\n    padding: 1px;\n    border-radius: 40px;\n    background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.02), rgba(15,255,255,0.1));\n    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);\n    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);\n    -webkit-mask-composite: xor;\n    mask-composite: exclude;\n    pointer-events: none;\n}\n\n/* Light Mode Variations */\n.light-mode {\n    background-color: #f8fafc;\n}\n.light-mode .aero-root {\n    background-color: #f8fafc;\n}\n.light-mode .orb-indigo { background-color: rgba(111, 0, 255, 0.1); }\n.light-mode .orb-cyan { background-color: rgba(15, 255, 255, 0.1); }\n.light-mode .orb-violet { background-color: rgba(143, 0, 255, 0.1); }\n.light-mode .frosted-panel {\n    background-color: rgba(255, 255, 255, 0.6);\n    border-color: rgba(0, 0, 0, 0.05);\n    box-shadow: 0 32px 64px -16px rgba(0,0,0,0.1);\n}\n.light-mode .text-white { color: #1e293b; }\n.light-mode .text-white\\/50 { color: #64748b; }\n.light-mode .text-white\\/40 { color: #94a3b8; }\n.light-mode .text-white\\/20 { color: #cbd5e1; }\n.light-mode .bg-black\\/20 { background-color: rgba(0,0,0,0.02); }\n.light-mode .bg-white\\/5 { background-color: rgba(0,0,0,0.03); }\n.light-mode .border-white\\/10 { border-color: rgba(0,0,0,0.05); }\n.light-mode input {\n    background-color: rgba(0,0,0,0.02);\n    color: #1e293b;\n    border-color: rgba(0,0,0,0.05);\n}\n.light-mode input::placeholder { color: #94a3b8; }\n</style>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"78\"></script>\n<script type=\"module\" data-kid=\"79\">\n    import { animate, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n    import { animate as animeAnimate } from 'https://esm.sh/animejs@4';\n\n    // 1. Icons Initialization\n    import { createIcons, Mail, Lock, Check, Eye, Sun, Moon, ArrowRight, Github, Twitter } from 'https://esm.sh/lucide@0.444.0';\n    createIcons({\n        icons: { Mail, Lock, Check, Eye, Sun, Moon, ArrowRight, Github, Twitter }\n    });\n\n    // 2. Ambient Mesh Gradient Animation (#anime-ambient-gradient)\n    animeAnimate('.orb-indigo', {\n        translateX: ['-10%', '15%', '-5%'],\n        translateY: ['-10%', '10%', '-5%'],\n        scale: [1, 1.2, 1],\n        duration: 15000,\n        loop: true,\n        direction: 'alternate',\n        easing: 'easeInOutQuad'\n    });\n\n    animeAnimate('.orb-cyan', {\n        translateX: ['5%', '-15%', '5%'],\n        translateY: ['10%', '-10%', '5%'],\n        scale: [1, 1.1, 1],\n        duration: 18000,\n        loop: true,\n        direction: 'alternate',\n        easing: 'easeInOutQuad'\n    });\n\n    animeAnimate('.orb-violet', {\n        translateX: ['-5%', '10%', '-5%'],\n        translateY: ['-5%', '15%', '-5%'],\n        scale: [1, 1.3, 1],\n        duration: 20000,\n        loop: true,\n        direction: 'alternate',\n        easing: 'easeInOutQuad'\n    });\n\n    // 3. SVG Path Morph (#anime-path-morph)\n    const morphPath = document.querySelector('#morph-path');\n    const targetPath = document.querySelector('#target-path');\n    \n    // Enhanced initial path for more visual interest\n    const initialPath = \"M160,100c0,33.1-26.9,60-60,60s-60-26.9-60-60c0-33.1,26.9-60,60-60S160,66.9,160,100z\";\n    const complexBlob = \"M163.5,100c0,35.1-28.4,63.5-63.5,63.5S36.5,135.1,36.5,100s42.4-78.5,77.5-63.5S163.5,64.9,163.5,100z\";\n    \n    morphPath.setAttribute('d', initialPath);\n\n    animeAnimate(morphPath, {\n        d: [\n            { value: initialPath },\n            { value: complexBlob },\n            { value: targetPath.getAttribute('d') }\n        ],\n        duration: 8000,\n        easing: 'easeInOutQuad',\n        loop: true,\n        direction: 'alternate'\n    });\n\n    // 4. Entrance Animation (#gsap-fade-up)\n    window.addEventListener('DOMContentLoaded', () => {\n        const tl = gsap.timeline();\n        \n        tl.to('#login-card', {\n            autoAlpha: 1,\n            y: 0,\n            duration: 1.2,\n            ease: 'expo.out'\n        });\n\n        tl.from('.form-group', {\n            autoAlpha: 0,\n            y: 24,\n            duration: 0.8,\n            stagger: 0.08,\n            ease: 'power3.out'\n        }, \"-=0.6\");\n        \n        tl.from('.header-animate', {\n            autoAlpha: 0,\n            y: 20,\n            duration: 0.7,\n            stagger: 0.1,\n            ease: 'power3.out'\n        }, \"-=1.2\");\n    });\n\n    // 5. Theme Toggle Logic\n    const themeBtn = document.getElementById('theme-btn');\n    const toggleIndicator = document.getElementById('toggle-indicator');\n    const root = document.querySelector('.aero-root');\n    let isDarkMode = true;\n\n    themeBtn.addEventListener('click', () => {\n        isDarkMode = !isDarkMode;\n        \n        if (isDarkMode) {\n            root.classList.remove('light-mode');\n            toggleIndicator.style.left = '4px';\n            toggleIndicator.style.backgroundColor = 'white';\n        } else {\n            root.classList.add('light-mode');\n            toggleIndicator.style.left = 'calc(100% - 28px)';\n            toggleIndicator.style.backgroundColor = '#6F00FF';\n        }\n    });\n\n    // 6. Form Button Micro-interaction (#motion-hover-glow)\n    const submitBtn = document.getElementById('submit-btn');\n    submitBtn.addEventListener('pointerenter', () => {\n        animate(submitBtn, { \n            boxShadow: '0 20px 60px rgba(111, 0, 255, 0.6)',\n            scale: 1.02\n        }, { duration: 0.3 });\n    });\n    submitBtn.addEventListener('pointerleave', () => {\n        animate(submitBtn, { \n            boxShadow: '0 20px 40px -12px rgba(111, 0, 255, 0.4)',\n            scale: 1\n        }, { duration: 0.3 });\n    });\n\n</script>\n",
