iv>\n            \n            <div id=\"notification-stack\" class=\"flex flex-col gap-4 overflow-y-auto custom-scrollbar flex-1 pr-2\" data-kid=\"147\">\n              \n              <div class=\"toast glass p-4 rounded-xl border-l-4 border-blue-400 flex flex-col gap-1 relative overflow-hidden group\" data-kid=\"148\">\n                <div class=\"absolute inset-0 bg-blue-500/5 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"149\"></div>\n                <div class=\"flex justify-between items-start\" data-kid=\"150\">\n                  <span class=\"text-[10px] font-bold text-blue-400 bg-blue-500/10 px-2 py-0.5 rounded-full uppercase\" data-kid=\"151\">Conflict</span>\n                  <span class=\"text-[10px] text-[#C0C0C0]/40\" data-kid=\"152\">09:45 AM</span>\n                </div>\n                <p class=\"text-xs font-bold mt-1\" data-kid=\"153\">Room Overlap Detected</p>\n                <p class=\"text-[11px] text-[#C0C0C0]/60\" data-kid=\"154\">Lecture Hall B has two classes scheduled for 10:00 AM.</p>\n              </div>\n\n              \n              <div class=\"toast glass p-4 rounded-xl border-l-4 border-emerald-400 flex flex-col gap-1 relative overflow-hidden group\" data-kid=\"155\">\n                <div class=\"absolute inset-0 bg-emerald-500/5 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"156\"></div>\n                <div class=\"flex justify-between items-start\" data-kid=\"157\">\n                  <span class=\"text-[10px] font-bold text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded-full uppercase\" data-kid=\"158\">Leave</span>\n                  <span class=\"text-[10px] text-[#C0C0C0]/40\" data-kid=\"159\">10:15 AM</span>\n                </div>\n                <p class=\"text-xs font-bold mt-1\" data-kid=\"160\">Faculty Leave Request</p>\n                <p class=\"text-[11px] text-[#C0C0C0]/60\" data-kid=\"161\">Dr. Sarah Jenkins submitted a leave request for tomorrow.</p>\n        