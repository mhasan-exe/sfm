      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap');\n\n  :root {\n    --bg-deep: #010B13;\n    --primary: #6F00FF;\n    --accent: #0FFFFF;\n    --secondary: #8F00FF;\n    --glass-bg: rgba(255, 255, 255, 0.05);\n    --glass-border: rgba(255, 255, 255, 0.1);\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: var(--bg-deep);\n    font-family: 'Inter', sans-serif;\n    color: white;\n    overflow-x: hidden;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .font-heading { font-family: 'Plus Jakarta Sans', sans-serif; }\n  .font-body { font-family: 'Inter', sans-serif; }\n\n  /* Glassmorphism utility - NO CSS transitions for GSAP-animated properties */\n  .glass {\n    background: var(--glass-bg);\n    backdrop-filter: blur(24px);\n    -webkit-backdrop-filter: blur(24px);\n    border: 1px solid var(--glass-border);\n  }\n\n  /* Specific mesh orb styling */\n  .mesh-orb {\n    position: absolute;\n    border-radius: 50%;\n    filter: blur(100px);\n    opacity: 0.6;\n    pointer-events: none;\n    z-index: 0;\n  }\n\n  /* Success state reveal overlay */\n  .reveal-overlay {\n    position: fixed;\n    inset: 0;\n    clip-path: circle(0% at 50% 50%);\n    background: linear-gradient(135deg, #6F00FF, #0FFFFF);\n    z-index: 100;\n    display: none;\n  }\n\n  /* Custom input focus glow - controlled by CSS focus-within */\n  .input-focus-glow:focus-within {\n    box-shadow: 0 0 20px rgba(15, 255, 255, 0.15);\n    border-color: rgba(15, 255, 255, 0.4);\n  }\n\n  /* Hide scrollbar */\n  ::-webkit-scrollbar { display: none; }\n</style>\n\n<div class=\"relative w-full min-h-screen flex flex-col items-center justify-start px-6 pt-12 pb-16 overflow-hidden\" data-kid=\"1\">\n  \n  \n  <div id=\"mesh-container\" class=\"fixed inset-0 overflow-hidden pointer-events-none\" data-kid=\"2\">\n    <div id=\"orb-1\" class=\"mesh-orb w-[400px] h-[400px] bg-[#6F00FF]\" style=\"top: -10%; left: -20%;\" data-kid=\"3\"></div>\n    <div id=\"orb-2\" class=\"mesh-orb w-[500px] h-[500px] bg-[#8F00FF]\" style=\"bottom: -10%; right: -20%;\" data-kid=\"4\"></div>\n    <div id=\"orb-3\" class=\"mesh-orb w-[300px] h-[300px] bg-[#0FFFFF]\" style=\"top: 30%; right: -10%;\" data-kid=\"5\"></div>\n  </div>\n\n  \n  <div class=\"fixed inset-0 pointer-events-none opacity-20\" data-kid=\"6\">\n    <svg class=\"absolute top-[15%] left-[10%] w-32 h-32 text-white\" viewBox=\"0 0 100 100\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"7\">\n      <circle cx=\"50\" cy=\"50\" r=\"48\" stroke=\"currentColor\" stroke-width=\"0.5\" stroke-dasharray=\"4 4\" data-kid=\"8\"></circle>\n    </svg>\n    <svg class=\"absolute bottom-[20%] right-[5%] w-48 h-48 text-white\" viewBox=\"0 0 100 100\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"9\">\n      <rect x=\"10\" y=\"10\" width=\"80\" height=\"80\" stroke=\"currentColor\" stroke-width=\"0.5\" transform=\"rotate(45 50 50)\" data-kid=\"10\"></rect>\n    </svg>\n  </div>\n\n  \n  <header class=\"header-nav w-full max-w-[375px] flex justify-between items-center z-50 mb-8\" style=\"opacity: 0;\" data-kid=\"11\">\n    <div class=\"flex items-center gap-2\" data-kid=\"12\">\n      <div class=\"w-8 h-8 rounded-xl bg-gradient-to-tr from-[#6F00FF] to-[#0FFFFF] flex items-center justify-center shadow-lg shadow-[#6F00FF]/30\" data-kid=\"13\">\n        <span class=\"font-heading font-extrabold text-xs text-white\" data-kid=\"14\">A</span>\n      </div>\n      <span class=\"font-heading font-bold text-lg tracking-tight text-white\" data-kid=\"15\">AKESP</span>\n    </div>\n    \n    \n    <div id=\"theme-toggle\" class=\"glass rounded-full p-1 flex items-center gap-2 cursor-pointer active:scale-95\" data-kid=\"16\">\n      <div class=\"w-8 h-8 rounded-full flex items-center justify-center bg-white/10\" data-kid=\"17\">\n        <svg id=\"sun-moon-morph\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"18\">\n          <path id=\"morphing-path\" d=\"M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z\" data-kid=\"19\"></path>\n        </svg>\n      </div>\n      <div class=\"pr-3 text-[10px] font-heading font-bold uppercase tracking-widest text-white/50\" data-kid=\"20\">Dark</div>\n    </div>\n  </header>\n\n  \n  <div class=\"hero-shape relative z-10 w-full max-w-[375px] aspect-square flex items-center justify-center mb-6\" style=\"opacity: 0;\" data-kid=\"21\">\n    <div class=\"absolute inset-0 bg-[#0FFFFF]/5 blur-[60px] rounded-full animate-pulse\" data-kid=\"22\"></div>\n    <svg viewBox=\"0 0 200 200\" xmlns=\"http://www.w3.org/2000/svg\" class=\"w-64 h-64 drop-shadow-[0_0_30px_rgba(111,0,255,0.4)]\" data-kid=\"23\">\n      <path id=\"liquid-morph\" fill=\"url(#main-grad)\" d=\"M44.7,-76.4C58.1,-69.2,69.5,-57.4,77.3,-43.8C85.1,-30.2,89.2,-15.1,87.4,-0.9C85.7,13.2,78,26.4,69.1,38.1C60.2,49.8,50,60,38.2,67.8C26.3,75.6,12.8,81.1,-0.8,82.4C-14.4,83.8,-28.8,81.1,-41.2,73.5C-53.6,65.9,-64,53.4,-71.4,39.8C-78.8,26.2,-83.2,11.5,-82.7,-3.1C-82.3,-17.7,-77,-32.2,-68.2,-44.2C-59.4,-56.3,-47.1,-65.9,-34.2,-73.4C-21.3,-80.9,-7.8,-86.3,6.3,-97.2C20.4,-108.1,31.3,-83.6,44.7,-76.4Z\" transform=\"translate(100 100)\" data-kid=\"24\"></path>\n      <defs data-kid=\"25\">\n        <linearGradient id=\"main-grad\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\" data-kid=\"26\">\n          <stop offset=\"0%\" stop-color=\"#6F00FF\" data-kid=\"27\"></stop>\n          <stop offset=\"100%\" stop-color=\"#0FFFFF\" data-kid=\"28\"></stop>\n        </linearGradient>\n      </defs>\n    </svg>\n  </div>\n\n  \n  <main class=\"login-card w-full max-w-[375px] glass rounded-[40px] p-8 relative overflow-hidden\" style=\"opacity: 0;\" data-kid=\"29\">\n    <div class=\"absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-[#0FFFFF]/50 to-transparent\" data-kid=\"30\"></div>\n    \n    <div class=\"mb-10 text-center\" data-kid=\"31\">\n      <h1 class=\"text-4xl font-heading font-extrabold mb-3 tracking-tight text-white\" data-kid=\"32\">Portal Access</h1>\n      <p class=\"text-white/50 font-body text-sm leading-relaxed px-4\" data-kid=\"33\">Identify yourself to access the <span class=\"text-[#0FFFFF]\" data-kid=\"34\">Aero Timetable</span> ecosystem.</p>\n    </div>\n\n    <form id=\"login-form\" class=\"space-y-6\" data-kid=\"35\">\n      <div class=\"space-y-2\" data-kid=\"36\">\n        <label class=\"text-[10px] font-heading font-extrabold uppercase tracking-[0.2em] text-[#0FFFFF] ml-1\" data-kid=\"37\">Authentication ID</label>\n        <div class=\"glass rounded-2xl flex items-center px-5 py-4 input-focus-glow\" data-kid=\"38\">\n          <svg class=\"w-5 h-5 text-white/30 mr-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"39\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z\" data-kid=\"40\"></path>\n          </svg>\n          <input type=\"text\" placeholder=\"username@akesp\" class=\"w-full bg-transparent border-none outline-hidden font-body text-sm placeholder:text-white/20 text-white\" data-kid=\"41\">\n        </div>\n      </div>\n\n      <div class=\"space-y-2\" data-kid=\"42\">\n        <label class=\"text-[10px] font-heading font-extrabold uppercase tracking-[0.2em] text-[#0FFFFF] ml-1\" data-kid=\"43\">Security Key</label>\n        <div class=\"glass rounded-2xl flex items-center px-5 py-4 input-focus-glow\" data-kid=\"44\">\n          <svg class=\"w-5 h-5 text-white/30 mr-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"45\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\" data-kid=\"46\"></path>\n          </svg>\n          <input type=\"password\" placeholder=\"••••••••\" class=\"w-full bg-transparent border-none outline-hidden font-body text-sm placeholder:text-white/20 text-white\" data-kid=\"47\">\n        </div>\n      </div>\n\n      <button type=\"submit\" id=\"submit-btn\" class=\"relative w-full group overflow-hidden bg-[#6F00FF] text-white font-heading font-extrabold text-sm py-5 rounded-2xl shadow-[0_20px_40px_rgba(111,0,255,0.3)] active:scale-[0.98]\" data-kid=\"48\">\n        <div class=\"absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000\" data-kid=\"49\"></div>\n        <span class=\"relative z-10 flex items-center justify-center gap-2\" data-kid=\"50\">\n          AUTHENTICATE <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"51\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 7l5 5m0 0l-5 5m5-5H6\" data-kid=\"52\"></path></svg>\n        </span>\n      </button>\n    </form>\n\n    <div class=\"mt-10 flex flex-col items-center gap-4 text-xs font-body text-white/30\" data-kid=\"53\">\n      <div class=\"flex items-center gap-4\" data-kid=\"54\">\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"55\">Forgotten Key?</a>\n        <div class=\"w-1 h-1 rounded-full bg-white/10\" data-kid=\"56\"></div>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"57\">New Request</a>\n      </div>\n      <p class=\"text-[10px] tracking-wide uppercase opacity-50\" data-kid=\"58\">Secure Aero Environment v2.4.0</p>\n    </div>\n  </main>\n\n  <div class=\"reveal-overlay\" data-kid=\"59\"></div>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"60\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"61\"></script>\n<script data-kid=\"62\">gsap.registerPlugin(ScrollTrigger);</script>\n<script type=\"module\" data-kid=\"63\">\n  import { animate as animeAnimate } from 'https://esm.sh/animejs@4';\n\n  const triggerSuccess = () => {\n    const overlay = document.querySelector('.reveal-overlay');\n    if (!overlay) return;\n    overlay.style.display = 'block';\n    gsap.to(overlay, {\n      clipPath: 'circle(150% at 50% 50%)',\n      duration: 1.2,\n      ease: 'power3.inOut',\n      onComplete: () => {\n        document.body.innerHTML = `\n          <div class=\"success-screen w-full h-screen flex flex-col items-center justify-center bg-white text-[#010B13] font-heading p-10 text-center\">\n            <div class=\"w-20 h-20 bg-[#6F00FF] rounded-full flex items-center justify-center mb-6 text-white text-3xl\">✓</div>\n            <h1 class=\"text-4xl font-extrabold mb-2\">Access Granted</h1>\n            <p class=\"text-lg opacity-60\">Redirecting to Timetable Dashboard...</p>\n          </div>\n        `;\n        gsap.from(\".success-screen\", { opacity: 0, y: 20, duration: 1 });\n      }\n    });\n  };\n\n  const init = () => {\n    const loginForm = document.getElementById('login-form');\n    if (loginForm) {\n      loginForm.addEventListener('submit', (e) => {\n        e.preventDefault();\n        triggerSuccess();\n      });\n    }\n\n    // --- Background Ambient Drift (#anime-ambient-gradient) ---\n    animeAnimate('.mesh-orb', {\n      translateX: () => animeAnimate.random(-150, 150),\n      translateY: () => animeAnimate.random(-150, 150),\n      scale: () => animeAnimate.random(0.7, 1.3),\n      duration: 18000,\n      direction: 'alternate',\n      loop: true,\n      easing: 'easeInOutSine'\n    });\n\n    // --- Liquid Shape Morphing (#anime-path-morph) ---\n    const morphPaths = [\n      \"M44.7,-76.4C58.1,-69.2,69.5,-57.4,77.3,-43.8C85.1,-30.2,89.2,-15.1,87.4,-0.9C85.7,13.2,78,26.4,69.1,38.1C60.2,49.8,50,60,38.2,67.8C26.3,75.6,12.8,81.1,-0.8,82.4C-14.4,83.8,-28.8,81.1,-41.2,73.5C-53.6,65.9,-64,53.4,-71.4,39.8C-78.8,26.2,-83.2,11.5,-82.7,-3.1C-82.3,-17.7,-77,-32.2,-68.2,-44.2C-59.4,-56.3,-47.1,-65.9,-34.2,-73.4C-21.3,-80.9,-7.8,-86.3,6.3,-97.2C20.4,-108.1,31.3,-83.6,44.7,-76.4Z\",\n      \"M52.3,-88.7C65.5,-80.5,72.4,-62.3,78.2,-45.8C83.9,-29.3,88.5,-14.7,87.1,0.8C85.6,16.3,78.2,32.6,69.4,46.7C60.7,60.8,50.7,72.6,37.5,79.5C24.4,86.4,8,88.3,-8.6,87.4C-25.2,86.5,-42,82.8,-56,74.1C-70.1,65.4,-81.4,51.8,-86.7,36.4C-91.9,21,-91,3.8,-87.3,-12.3C-83.5,-28.4,-77,-43.5,-66.1,-54.6C-55.2,-65.7,-40,-72.7,-25.9,-80.4C-11.8,-88.1,1.1,-96.5,18.8,-96.9C36.6,-97.4,39.1,-96.8,52.3,-88.7Z\",\n      \"M36.7,-64.3C48.9,-58.3,61,-50.3,68.9,-38.9C76.8,-27.5,80.5,-12.7,78.6,1.1C76.8,14.8,69.4,27.5,60.1,38.5C50.8,49.5,39.6,58.8,26.8,65.5C14.1,72.2,-0.2,76.3,-15,74.7C-29.8,73.1,-45.1,65.7,-57.1,54.7C-69.1,43.6,-77.8,28.9,-81.1,13.2C-84.4,-2.5,-82.3,-19.1,-74.6,-32.8C-66.9,-46.5,-53.7,-57.3,-40.1,-62.7C-26.6,-68.2,-12.7,-68.3,0.3,-68.9C13.4,-69.5,24.5,-70.3,36.7,-64.3Z\"\n    ];\n\n    let currentPathIndex = 0;\n    const cycleMorph = () => {\n      const nextPath = morphPaths[(currentPathIndex + 1) % morphPaths.length];\n      animeAnimate('#liquid-morph', {\n        d: nextPath,\n        duration: 5000,\n        easing: 'easeInOutSine',\n        complete: () => {\n          currentPathIndex = (currentPathIndex + 1) % morphPaths.length;\n          cycleMorph();\n        }\n      });\n    }\n    cycleMorph();\n\n    // --- Entrance Reveal (#gsap-fade-up) ---\n    const tl = gsap.timeline({ defaults: { ease: \"power4.out\" } });\n    tl.to(\".header-nav\", { opacity: 1, y: 0, duration: 1, startAt: { y: -20, opacity: 0 } })\n      .to(\".hero-shape\", { opacity: 1, scale: 1, duration: 1.2, startAt: { scale: 0.8, opacity: 0 } }, \"-=0.6\")\n      .to(\".login-card\", { opacity: 1, y: 0, duration: 1, startAt: { y: 40, opacity: 0 } }, \"-=0.8\");\n\n    // --- Toggle Icon Morph (#anime-hover-icon-morph) ---\n    const moonPath = \"M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z\";\n    const sunPath = \"M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10ZM12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42\";\n    \n    let isDarkMode = true;\n    document.getElementById('theme-toggle').addEventListener('click', () => {\n      isDarkMode = !isDarkMode;\n      const path = isDarkMode ? moonPath : sunPath;\n      const label = isDarkMode ? \"Dark\" : \"Light\";\n      \n      animeAnimate('#morphing-path', {\n        d: path,\n        duration: 500,\n        easing: 'easeInOutQuad'\n      });\n      \n      document.querySelector('#theme-toggle .text-white\\\\/50').textContent = label;\n      \n      gsap.to(\"body\", { \n        backgroundColor: isDarkMode ? \"#010B13\" : \"#f0f4f8\", \n        color: isDarkMode ? \"#ffffff\" : \"#010B13\", \n        duration: 0.8 \n      });\n      gsap.to(\".glass\", {\n        backgroundColor: isDarkMode ? \"rgba(255, 255, 255, 0.05)\" : \"rgba(0, 0, 0, 0.03)\",\n        borderColor: isDarkMode ? \"rgba(255, 255, 255, 0.1)\" : \"rgba(0, 0, 0, 0.05)\",\n        duration: 0.8\n      });\n    });\n  };\n\n  init();\n</script>\n",
