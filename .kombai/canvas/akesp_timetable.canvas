      "html": "<div class=\"min-h-screen w-full flex flex-col items-center justify-center bg-[#011F5B] font-['DM_Sans'] text-[#C0C0C0] relative overflow-hidden\" id=\"app-root\" data-kid=\"0\">\n    \n    \n    <div class=\"absolute top-[-10%] right-[-15%] w-80 h-80 bg-[#C0C0C0]/10 rounded-full blur-[100px] pointer-events-none opacity-50\" data-kid=\"1\"></div>\n    <div class=\"absolute bottom-[-5%] left-[-15%] w-96 h-96 bg-[#36454F]/50 rounded-full blur-[120px] pointer-events-none opacity-40\" data-kid=\"2\"></div>\n    <div class=\"absolute top-1/4 left-1/2 -translate-x-1/2 w-[150%] h-[150%] bg-radial-gradient from-transparent via-[#011F5B]/10 to-[#36454F]/10 pointer-events-none\" data-kid=\"3\"></div>\n\n    \n    <div class=\"w-full max-w-[375px] px-6 py-10 relative z-10 flex flex-col min-h-screen justify-between overflow-y-auto no-scrollbar\" data-kid=\"4\">\n        \n        \n        <div class=\"fade-up-element flex flex-col items-center space-y-5 mb-8\" data-kid=\"5\">\n            <div class=\"relative group\" data-kid=\"6\">\n                <div class=\"absolute -inset-6 bg-[#C0C0C0]/10 rounded-full blur-2xl pointer-events-none\" data-kid=\"7\"></div>\n                <div class=\"relative flex items-center justify-center w-20 h-20 rounded-[1.5rem] bg-white/[0.03] border border-white/10 backdrop-blur-xl shadow-2xl\" data-kid=\"8\">\n                    <i class=\"ti ti-school text-4xl text-[#C0C0C0]\" data-kid=\"9\"></i>\n                </div>\n            </div>\n            <div class=\"text-center space-y-1\" data-kid=\"10\">\n                <h1 class=\"text-3xl font-['Inter'] font-black text-white tracking-tighter leading-none\" data-kid=\"11\">EXECUTIVE <span class=\"text-[#C0C0C0]/60\" data-kid=\"12\">GLASS</span></h1>\n                <p class=\"text-[10px] text-[#C0C0C0]/30 uppercase tracking-[0.4em] font-bold\" data-kid=\"13\">AKESP Timetable System</p>\n            </div>\n        </div>\n\n        \n        <div class=\"card-container relative mb-8\" data-kid=\"14\">\n            \n            <div class=\"absolute inset-0 z-0 overflow-hidden rounded-[2.5rem] pointer-events-none\" data-kid=\"15\">\n                <div class=\"scan-line w-full h-20 bg-gradient-to-b from-transparent via-white/[0.04] to-transparent absolute top-0 left-0 -translate-y-full\" data-kid=\"16\"></div>\n            </div>\n\n            <div class=\"backdrop-blur-3xl bg-white/[0.06] border border-white/10 rounded-[2.5rem] p-8 shadow-[0_40px_100px_-30px_rgba(0,0,0,0.8)] relative overflow-hidden\" data-kid=\"17\">\n                \n                \n                <div class=\"absolute inset-0 rounded-[2.5rem] border border-white/5 pointer-events-none\" data-kid=\"18\"></div>\n\n                <div class=\"space-y-7 relative z-10\" data-kid=\"19\">\n                    <div class=\"fade-up-element space-y-1.5 text-center\" data-kid=\"20\">\n                        <h2 class=\"text-2xl font-['Inter'] font-bold text-white tracking-tight\" data-kid=\"21\">Security Portal</h2>\n                        <p class=\"text-[#C0C0C0]/40 text-xs font-medium\" data-kid=\"22\">Authentication required for access</p>\n                    </div>\n\n                    \n                    <div class=\"space-y-5 pt-2\" data-kid=\"23\">\n                        <div class=\"fade-up-element space-y-2\" data-kid=\"24\">\n                            <label class=\"text-[9px] font-black uppercase tracking-[0.2em] text-[#C0C0C0]/50 ml-1\" data-kid=\"25\">Terminal Address</label>\n                            <div class=\"relative group\" data-kid=\"26\">\n                                <i class=\"ti ti-mail absolute left-5 top-1/2 -translate-y-1/2 text-white/30 group-focus-within:text-[#C0C0C0] transition-colors duration-300\" data-kid=\"27\"></i>\n                                <input type=\"email\" placeholder=\"admin.node@akesp.org\" class=\"w-full bg-white/[0.08] border border-white/10 rounded-2xl pl-13 pr-6 py-4.5 text-white text-sm placeholder:text-white/40 outline-hidden focus:border-[#C0C0C0]/50 focus:bg-white/[0.12] focus:ring-1 focus:ring-[#C0C0C0]/20 transition-all duration-300\" data-kid=\"28\">\n                            </div>\n                        </div>\n\n                        <div class=\"fade-up-element space-y-2\" data-kid=\"29\">\n                            <label class=\"text-[9px] font-black uppercase tracking-[0.2em] text-[#C0C0C0]/50 ml-1\" data-kid=\"30\">Encrypted Key</label>\n                            <div class=\"relative group\" data-kid=\"31\">\n                                <i class=\"ti ti-lock absolute left-5 top-1/2 -translate-y-1/2 text-white/30 group-focus-within:text-[#C0C0C0] transition-colors duration-300\" data-kid=\"32\"></i>\n                                <input type=\"password\" placeholder=\"••••••••\" class=\"w-full bg-white/[0.08] border border-white/10 rounded-2xl pl-13 pr-6 py-4.5 text-white text-sm placeholder:text-white/40 outline-hidden focus:border-[#C0C0C0]/50 focus:bg-white/[0.12] focus:ring-1 focus:ring-[#C0C0C0]/20 transition-all duration-300\" data-kid=\"33\">\n                            </div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"space-y-4 pt-2\" data-kid=\"34\">\n                        <div class=\"fade-up-element\" data-kid=\"35\">\n                            <button class=\"w-full py-5 rounded-2xl bg-gradient-to-br from-[#E5E4E2] via-[#C0C0C0] to-[#929292] text-[#011F5B] font-black text-xs uppercase tracking-[0.3em] shadow-[0_12px_24px_-8px_rgba(192,192,192,0.5)] active:scale-[0.98] cursor-pointer hover:brightness-105\" data-kid=\"36\">\n                                Authenticate\n                            </button>\n                        </div>\n                        \n                        <div class=\"fade-up-element flex items-center gap-4 py-4\" data-kid=\"37\">\n                            <div class=\"h-[1px] grow bg-gradient-to-r from-transparent via-white/10 to-transparent\" data-kid=\"38\"></div>\n                            <span class=\"text-[8px] uppercase tracking-[0.5em] text-[#C0C0C0]/40 font-black\" data-kid=\"39\">Gateways</span>\n                            <div class=\"h-[1px] grow bg-gradient-to-r from-transparent via-white/10 to-transparent\" data-kid=\"40\"></div>\n                        </div>\n\n                        <div class=\"fade-up-element\" data-kid=\"41\">\n                            <button class=\"w-full flex items-center justify-center gap-3 px-6 py-4 rounded-2xl bg-white/[0.04] border border-white/10 hover:bg-white/[0.08] active:scale-[0.98] group cursor-pointer transition-all duration-300\" data-kid=\"42\">\n                                <svg class=\"w-5 h-5 opacity-90 group-hover:opacity-100\" viewBox=\"0 0 24 24\" data-kid=\"43\">\n                                    <path fill=\"#4285F4\" d=\"M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z\" data-kid=\"44\"></path>\n                                    <path fill=\"#34A853\" d=\"M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z\" data-kid=\"45\"></path>\n                                    <path fill=\"#FBBC05\" d=\"M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z\" data-kid=\"46\"></path>\n                                    <path fill=\"#EA4335\" d=\"M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z\" data-kid=\"47\"></path>\n                                </svg>\n                                <span class=\"text-white/60 font-bold text-[10px] uppercase tracking-[0.2em] group-hover:text-white/90 transition-colors\" data-kid=\"48\">Continue with Google</span>\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"mt-auto pt-8 flex flex-col items-center space-y-7 pb-4\" data-kid=\"49\">\n            <div class=\"fade-up-element\" data-kid=\"50\">\n                <a href=\"#\" class=\"text-[9px] text-[#C0C0C0]/50 hover:text-white transition-colors flex items-center gap-2 group tracking-[0.3em] uppercase font-black\" data-kid=\"51\">\n                    <span data-kid=\"52\">Protocol Recovery</span>\n                    <i class=\"ti ti-chevron-right text-[10px] group-hover:translate-x-1 transition-transform\" data-kid=\"53\"></i>\n                </a>\n            </div>\n\n            <div class=\"fade-up-element\" data-kid=\"54\">\n                <div class=\"px-5 py-2.5 rounded-full bg-white/[0.04] border border-white/10 backdrop-blur-md flex items-center gap-3 shadow-[0_4px_20px_-5px_rgba(0,0,0,0.5)]\" data-kid=\"55\">\n                    <span class=\"w-1.5 h-1.5 rounded-full bg-green-500 shadow-[0_0_12px_rgba(34,197,94,0.8)] animate-pulse\" data-kid=\"56\"></span>\n                    <span class=\"text-[8px] uppercase tracking-[0.25em] text-[#C0C0C0]/40 font-black\" data-kid=\"57\">ACCESS POINT: MOBILE-01-EX</span>\n                </div>\n            </div>\n        </div>\n\n    </div>\n</div>\n\n<style data-kid=\"58\">\n@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;700&family=Inter:wght@400;600;700;900&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n:root {\n    --primary-navy: #011F5B;\n    --charcoal-blue: #36454F;\n    --silver-accent: #C0C0C0;\n}\n\nbody {\n    background-color: var(--primary-navy);\n    margin: 0;\n    padding: 0;\n    overflow: hidden;\n    user-select: none;\n}\n\n.no-scrollbar::-webkit-scrollbar {\n    display: none;\n}\n.no-scrollbar {\n    -ms-overflow-style: none;\n    scrollbar-width: none;\n}\n\n.py-4\\.5 {\n    padding-top: 1.125rem;\n    padding-bottom: 1.125rem;\n}\n\ninput::placeholder {\n    color: rgba(255, 255, 255, 0.05);\n}\n\n.backdrop-blur-3xl {\n    backdrop-filter: blur(80px);\n}\n\n.scan-line {\n    animation: scan 4s linear infinite;\n}\n\n@keyframes scan {\n    0% { transform: translateY(-100%); opacity: 0; }\n    10% { opacity: 0.5; }\n    90% { opacity: 0.5; }\n    100% { transform: translateY(400%); opacity: 0; }\n}\n\n.bg-radial-gradient {\n    background: radial-gradient(circle at 50% 50%, var(--tw-gradient-from), var(--tw-gradient-to));\n}\n</style>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"59\"></script>\n<script data-kid=\"60\">\ndocument.addEventListener('DOMContentLoaded', () => {\n    const tl = gsap.timeline({\n        defaults: {\n            ease: \"expo.out\",\n            duration: 1.4\n        }\n    });\n\n    // Initial state\n    gsap.set(\".card-container\", { autoAlpha: 0, y: 60, scale: 0.95 });\n    gsap.set(\".fade-up-element\", { autoAlpha: 0, y: 30 });\n\n    // Sequence\n    tl.to(\".card-container\", {\n        autoAlpha: 1,\n        y: 0,\n        scale: 1,\n        duration: 1.8,\n        delay: 0.2\n    })\n    .to(\".fade-up-element\", {\n        autoAlpha: 1,\n        y: 0,\n        stagger: 0.1,\n    }, \"-=1.4\");\n\n    // Dynamic background interaction\n    document.addEventListener('mousemove', (e) => {\n        const xPos = (e.clientX / window.innerWidth - 0.5) * 20;\n        const yPos = (e.clientY / window.innerHeight - 0.5) * 20;\n        \n        gsap.to(\".blur-[100px]\", {\n            x: xPos,\n            y: yPos,\n            duration: 2,\n            ease: \"power2.out\"\n        });\n    });\n});\n</script>",
