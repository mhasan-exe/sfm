      "html": "\n<div class=\"min-h-screen w-full flex bg-[#011F5B] font-['DM_Sans'] text-[#C0C0C0] overflow-hidden\" data-kid=\"0\">\n    \n    <div class=\"relative w-1/2 h-screen overflow-hidden hidden lg:block\" data-kid=\"1\">\n        <video src=\"https://videos.pexels.com/video-files/4047775/4047775-hd_1282_720_30fps.mp4\" poster=\"https://images.pexels.com/videos/4047775/etudes-milan-milano-4047775.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"absolute inset-0 w-full h-full object-cover scale-110 video-zoom\" decoding=\"async\" data-kid=\"2\"></video>\n        \n        <div class=\"absolute inset-0 bg-[#011F5B]/80 mix-blend-multiply\" data-kid=\"3\"></div>\n        <div class=\"absolute inset-0 bg-gradient-to-r from-transparent to-[#011F5B]\" data-kid=\"4\"></div>\n\n        <div class=\"absolute inset-0 flex flex-col justify-center p-24 z-10\" data-kid=\"5\">\n            <div class=\"space-y-8 max-w-xl\" data-kid=\"6\">\n                <div class=\"hero-line w-24 h-1 bg-[#C0C0C0] rounded-full\" data-kid=\"7\"></div>\n                <div class=\"space-y-4\" data-kid=\"8\">\n                    <h1 class=\"hero-title text-7xl font-['Inter'] font-black text-white leading-[1.1] tracking-tighter\" data-kid=\"9\">\n                        Executive <br data-kid=\"10\">\n                        <span class=\"text-[#C0C0C0]\" data-kid=\"11\">Glass</span> Interface\n                    </h1>\n                    <p class=\"hero-subtitle text-xl text-[#C0C0C0]/60 leading-relaxed font-light\" data-kid=\"12\">\n                        Precision-engineered for the modern institution. AKESP's ultimate timetable management system designed for high-level administrative oversight.\n                    </p>\n                </div>\n                \n                <div class=\"flex items-center gap-12 pt-12\" data-kid=\"13\">\n                    <div class=\"stat-item\" data-kid=\"14\">\n                        <div class=\"text-3xl font-bold text-white\" data-kid=\"15\">99.9%</div>\n                        <div class=\"text-xs uppercase tracking-[0.2em] text-[#C0C0C0]/40\" data-kid=\"16\">Uptime Reliability</div>\n                    </div>\n                    <div class=\"stat-item w-px h-10 bg-white/10\" data-kid=\"17\"></div>\n                    <div class=\"stat-item\" data-kid=\"18\">\n                        <div class=\"text-3xl font-bold text-white\" data-kid=\"19\">2.4k</div>\n                        <div class=\"text-xs uppercase tracking-[0.2em] text-[#C0C0C0]/40\" data-kid=\"20\">Active Faculty</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"absolute bottom-12 left-24 z-10 flex items-center gap-4\" data-kid=\"21\">\n            <div class=\"w-10 h-10 flex items-center justify-center rounded-lg bg-white/5 border border-white/10 backdrop-blur-sm\" data-kid=\"22\">\n                <i class=\"ti ti-building-community text-[#C0C0C0]\" data-kid=\"23\"></i>\n            </div>\n            <span class=\"text-sm tracking-[0.3em] font-medium text-white/40 uppercase\" data-kid=\"24\">Aga Khan Education Services</span>\n        </div>\n    </div>\n\n    \n    <div class=\"w-full lg:w-1/2 flex items-center justify-center p-8 lg:p-12 bg-gradient-to-bl from-[#36454F] to-[#011F5B] relative\" data-kid=\"25\">\n        \n        <div class=\"absolute top-20 right-20 w-64 h-64 bg-white/5 rounded-full blur-[100px]\" data-kid=\"26\"></div>\n        <div class=\"absolute bottom-20 left-20 w-64 h-64 bg-[#C0C0C0]/5 rounded-full blur-[100px]\" data-kid=\"27\"></div>\n\n        <div class=\"login-container w-full max-w-lg relative\" data-kid=\"28\">\n            \n            <div class=\"relative backdrop-blur-2xl bg-white/5 border border-white/10 rounded-[2.5rem] p-12 lg:p-16 shadow-[0_25px_50px_-12px_rgba(0,0,0,0.5)] overflow-hidden\" data-kid=\"29\">\n                \n                <div class=\"absolute inset-0 rounded-[2.5rem] border border-white/5 pointer-events-none\" data-kid=\"30\"></div>\n                \n                <div class=\"relative z-10 space-y-10\" data-kid=\"31\">\n                    \n                    <div class=\"fade-up text-center space-y-4\" data-kid=\"32\">\n                        <div class=\"inline-flex relative group\" data-kid=\"33\">\n                            <div class=\"absolute -inset-4 bg-[#C0C0C0]/20 rounded-full blur-xl group-hover:bg-[#C0C0C0]/30 transition-all duration-700\" data-kid=\"34\"></div>\n                            <div class=\"relative flex items-center justify-center w-20 h-20 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-md\" data-kid=\"35\">\n                                <i class=\"ti ti-school text-4xl text-[#C0C0C0]\" data-kid=\"36\"></i>\n                            </div>\n                        </div>\n                        <div class=\"space-y-1\" data-kid=\"37\">\n                            <h2 class=\"text-4xl font-['Inter'] font-bold text-white tracking-tight\" data-kid=\"38\">Welcome Back</h2>\n                            <p class=\"text-[#C0C0C0]/50 text-lg\" data-kid=\"39\">Sign in to AKESP Timetable System</p>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"space-y-6\" data-kid=\"40\">\n                        \n                        <div class=\"fade-up\" data-kid=\"41\">\n                            <button class=\"w-full group relative flex items-center justify-center gap-4 px-8 py-4.5 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-all duration-300\" data-kid=\"42\">\n                                <svg class=\"w-6 h-6\" viewBox=\"0 0 24 24\" data-kid=\"43\">\n                                    <path fill=\"#4285F4\" d=\"M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z\" data-kid=\"44\"></path>\n                                    <path fill=\"#34A853\" d=\"M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z\" data-kid=\"45\"></path>\n                                    <path fill=\"#FBBC05\" d=\"M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z\" data-kid=\"46\"></path>\n                                    <path fill=\"#EA4335\" d=\"M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z\" data-kid=\"47\"></path>\n                                </svg>\n                                <span class=\"text-white font-semibold text-lg\" data-kid=\"48\">Continue with Google</span>\n                            </button>\n                        </div>\n\n                        \n                        <div class=\"fade-up flex items-center gap-6\" data-kid=\"49\">\n                            <div class=\"h-px grow bg-gradient-to-r from-transparent via-white/10 to-transparent\" data-kid=\"50\"></div>\n                            <span class=\"text-[10px] uppercase tracking-[0.3em] text-[#C0C0C0]/30 font-bold whitespace-nowrap\" data-kid=\"51\">Corporate Credentials</span>\n                            <div class=\"h-px grow bg-gradient-to-r from-transparent via-white/10 to-transparent\" data-kid=\"52\"></div>\n                        </div>\n\n                        \n                        <div class=\"space-y-5\" data-kid=\"53\">\n                            <div class=\"fade-up space-y-2\" data-kid=\"54\">\n                                <label class=\"text-xs font-bold uppercase tracking-widest text-[#C0C0C0]/40 ml-1\" data-kid=\"55\">Email Terminal</label>\n                                <div class=\"relative\" data-kid=\"56\">\n                                    <i class=\"ti ti-mail absolute left-5 top-1/2 -translate-y-1/2 text-white/20\" data-kid=\"57\"></i>\n                                    <input type=\"email\" placeholder=\"executive@akesp.edu\" class=\"w-full bg-white/5 border border-white/10 rounded-2xl pl-14 pr-6 py-4.5 text-white placeholder:text-white/10 outline-none focus:border-[#C0C0C0]/40 focus:bg-white/[0.08] transition-all duration-300\" data-kid=\"58\">\n                                </div>\n                            </div>\n                            <div class=\"fade-up space-y-2\" data-kid=\"59\">\n                                <label class=\"text-xs font-bold uppercase tracking-widest text-[#C0C0C0]/40 ml-1\" data-kid=\"60\">Secure Passkey</label>\n                                <div class=\"relative\" data-kid=\"61\">\n                                    <i class=\"ti ti-lock absolute left-5 top-1/2 -translate-y-1/2 text-white/20\" data-kid=\"62\"></i>\n                                    <input type=\"password\" placeholder=\"••••••••\" class=\"w-full bg-white/5 border border-white/10 rounded-2xl pl-14 pr-6 py-4.5 text-white placeholder:text-white/10 outline-none focus:border-[#C0C0C0]/40 focus:bg-white/[0.08] transition-all duration-300\" data-kid=\"63\">\n                                </div>\n                            </div>\n                        </div>\n\n                        \n                        <div class=\"fade-up pt-4\" data-kid=\"64\">\n                            <button class=\"w-full py-5 rounded-2xl bg-gradient-to-br from-[#C0C0C0] via-[#E5E4E2] to-[#A9A9A9] text-[#011F5B] font-black text-lg uppercase tracking-widest shadow-[0_10px_30px_-10px_rgba(192,192,192,0.5)] hover:shadow-[0_15px_40px_-10px_rgba(192,192,192,0.6)] hover:-translate-y-0.5 active:scale-[0.98] transition-all duration-300\" data-kid=\"65\">\n                                Authenticate\n                            </button>\n                        </div>\n                    </div>\n\n                    <div class=\"fade-up text-center pt-4\" data-kid=\"66\">\n                        <a href=\"#\" class=\"text-sm text-[#C0C0C0]/30 hover:text-white transition-colors flex items-center justify-center gap-2 group\" data-kid=\"67\">\n                            <span data-kid=\"68\">System Recovery</span>\n                            <i class=\"ti ti-arrow-right text-xs group-hover:translate-x-1 transition-transform\" data-kid=\"69\"></i>\n                        </a>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"absolute -bottom-16 left-0 right-0 flex justify-center fade-up\" data-kid=\"70\">\n                <div class=\"px-4 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-md flex items-center gap-3\" data-kid=\"71\">\n                    <span class=\"w-2 h-2 rounded-full bg-green-500 animate-pulse\" data-kid=\"72\"></span>\n                    <span class=\"text-[10px] uppercase tracking-widest text-white/40 font-bold\" data-kid=\"73\">Terminal v4.2.0-EXECUTIVE</span>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n<style data-kid=\"74\">\n@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;700&family=Inter:wght@400;600;700;900&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\nbody {\n    margin: 0;\n    padding: 0;\n    overflow: hidden;\n    background-color: #011F5B;\n}\n\n.video-zoom {\n    animation: slowZoom 20s infinite alternate ease-in-out;\n}\n\n@keyframes slowZoom {\n    from { transform: scale(1.1); }\n    to { transform: scale(1.2); }\n}\n\n.py-4\\.5 {\n    padding-top: 1.125rem;\n    padding-bottom: 1.125rem;\n}\n\n/* Custom shadow for silver button */\n.btn-silver-shadow {\n    box-shadow: 0 0 0 0 rgba(192, 192, 192, 0);\n}\n</style>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"75\"></script>\n<script data-kid=\"76\">\ndocument.addEventListener('DOMContentLoaded', () => {\n    // Entrance Animations\n    const tl = gsap.timeline({ defaults: { ease: \"power4.out\" } });\n\n    tl.from(\".video-zoom\", {\n        opacity: 0,\n        duration: 2,\n        ease: \"power2.inOut\"\n    });\n\n    tl.from(\".hero-line\", {\n        scaleX: 0,\n        transformOrigin: \"left\",\n        duration: 1\n    }, \"-=1.5\");\n\n    tl.from(\".hero-title\", {\n        y: 50,\n        opacity: 0,\n        duration: 1.2\n    }, \"-=1\");\n\n    tl.from(\".hero-subtitle\", {\n        y: 20,\n        opacity: 0,\n        duration: 1\n    }, \"-=0.8\");\n\n    tl.from(\".stat-item\", {\n        y: 30,\n        opacity: 0,\n        stagger: 0.1,\n        duration: 1\n    }, \"-=0.6\");\n\n    tl.from(\".login-container\", {\n        x: 100,\n        opacity: 0,\n        duration: 1.5,\n        ease: \"expo.out\"\n    }, \"-=1.5\");\n\n    tl.from(\".fade-up\", {\n        y: 40,\n        opacity: 0,\n        stagger: 0.08,\n        duration: 1.2\n    }, \"-=1.2\");\n});\n</script>\n",
