      "html": "\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"0\">\n<style data-kid=\"1\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap');\n\n  :root {\n    --color-bg: #010B13;\n    --color-primary: #6F00FF;\n    --color-accent: #0FFFFF;\n    --color-secondary: #8F00FF;\n    --glass-bg: rgba(255, 255, 255, 0.05);\n    --glass-border: rgba(15, 255, 255, 0.2);\n    --card-bg: rgba(255, 255, 255, 0.03);\n  }\n\n  body {\n    background-color: var(--color-bg);\n    color: white;\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-heading { font-family: 'Plus Jakarta Sans', sans-serif; }\n\n  /* Gradient Mesh Background */\n  .gradient-mesh {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    z-index: -10;\n    overflow: hidden;\n    filter: blur(80px);\n  }\n\n  .orb {\n    position: absolute;\n    border-radius: 50%;\n    opacity: 0.5;\n  }\n\n  .orb-1 { width: 800px; height: 800px; background: var(--color-primary); top: -20%; left: -10%; }\n  .orb-2 { width: 600px; height: 600px; background: var(--color-secondary); bottom: -10%; right: -5%; }\n  .orb-3 { width: 500px; height: 500px; background: var(--color-accent); top: 30%; left: 40%; opacity: 0.2; }\n\n  /* Glassmorphism */\n  .glass {\n    background: var(--glass-bg);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border: 1px solid var(--glass-border);\n  }\n\n  /* Bento Grid Layout */\n  .dashboard-grid {\n    display: grid;\n    grid-template-columns: repeat(12, 1fr);\n    grid-template-rows: auto auto auto;\n    gap: 24px;\n  }\n\n  /* Custom Scrollbar for horizontal rail */\n  .no-scrollbar::-webkit-scrollbar {\n    display: none;\n  }\n  .no-scrollbar {\n    -ms-overflow-style: none;\n    scrollbar-width: none;\n  }\n\n  /* Radial Attendance Chart */\n  .attendance-ring {\n    width: 160px;\n    height: 160px;\n    border-radius: 50%;\n    background: conic-gradient(var(--color-accent) 88%, transparent 0);\n    position: relative;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    box-shadow: 0 0 40px rgba(15, 255, 255, 0.2);\n  }\n\n  .attendance-ring::before {\n    content: \"\";\n    position: absolute;\n    width: 82%;\n    height: 82%;\n    background: var(--color-bg);\n    border-radius: 50%;\n    border: 1px solid rgba(255, 255, 255, 0.05);\n  }\n\n  .attendance-ring .inner-text {\n    position: relative;\n    z-index: 10;\n    text-align: center;\n  }\n\n  /* Floating sidebar nav rail */\n  .nav-rail {\n    position: sticky;\n    top: 24px;\n    height: calc(100vh - 48px);\n    width: 72px;\n    margin-right: 24px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 24px 0;\n    border-radius: 30px;\n  }\n\n  /* GSAP Elements base state */\n  .gsap-reveal { opacity: 0; }\n\n  /* Notification accent pulse */\n  .pulse-dot {\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n    background-color: #ef4444;\n    box-shadow: 0 0 10px rgba(239, 68, 68, 0.6);\n  }\n\n  /* Card Hover Overlays */\n  .card-overlay {\n    position: absolute;\n    inset: 0;\n    background: radial-gradient(circle at center, rgba(15, 255, 255, 0.05) 0%, transparent 70%);\n    opacity: 0;\n    pointer-events: none;\n  }\n\n</style>\n\n\n<div class=\"gradient-mesh aurora\" id=\"mesh-bg\" data-kid=\"2\">\n  <div class=\"orb orb-1\" data-kid=\"3\"></div>\n  <div class=\"orb orb-2\" data-kid=\"4\"></div>\n  <div class=\"orb orb-3\" data-kid=\"5\"></div>\n</div>\n\n<div class=\"min-h-screen flex p-6 relative\" data-kid=\"6\">\n  \n  <div class=\"fixed top-6 right-6 z-50\" data-kid=\"7\">\n    <div class=\"glass px-5 py-2.5 rounded-full flex items-center gap-3 cursor-pointer group\" id=\"theme-toggle\" data-kid=\"8\">\n      <div class=\"w-8 h-8 rounded-full bg-white/10 flex items-center justify-center\" id=\"theme-icon\" data-kid=\"9\">\n        <i class=\"fa-solid fa-moon text-xs\" data-kid=\"10\"></i>\n      </div>\n      <span class=\"text-xs font-bold uppercase tracking-widest opacity-70 group-hover:opacity-100 transition-opacity\" data-kid=\"11\">Dark Mode</span>\n    </div>\n  </div>\n\n  \n  <nav class=\"nav-rail glass gsap-reveal\" data-kid=\"12\">\n    <div class=\"mb-10 text-[var(--color-accent)] animate-pulse\" data-kid=\"13\">\n      <i class=\"fa-solid fa-wind text-3xl\" data-kid=\"14\"></i>\n    </div>\n    \n    <div class=\"flex flex-col gap-6 flex-1\" data-kid=\"15\">\n      <div class=\"w-12 h-12 flex items-center justify-center rounded-2xl bg-[var(--color-accent)] text-black shadow-[0_0_20px_rgba(15,255,255,0.4)] cursor-pointer\" data-kid=\"16\">\n        <i class=\"fa-solid fa-house-chimney text-lg\" data-kid=\"17\"></i>\n      </div>\n      <div class=\"w-12 h-12 flex items-center justify-center rounded-2xl hover:bg-white/10 text-white/50 hover:text-white cursor-pointer group relative\" data-kid=\"18\">\n        <i class=\"fa-solid fa-calendar-week text-lg\" data-kid=\"19\"></i>\n        <div class=\"absolute left-full ml-4 px-2 py-1 bg-black/80 text-[10px] rounded opacity-0 group-hover:opacity-100 pointer-events-none whitespace-nowrap\" data-kid=\"20\">Timetable</div>\n      </div>\n      <div class=\"w-12 h-12 flex items-center justify-center rounded-2xl hover:bg-white/10 text-white/50 hover:text-white cursor-pointer group relative\" data-kid=\"21\">\n        <i class=\"fa-solid fa-book-open-reader text-lg\" data-kid=\"22\"></i>\n        <div class=\"absolute left-full ml-4 px-2 py-1 bg-black/80 text-[10px] rounded opacity-0 group-hover:opacity-100 pointer-events-none whitespace-nowrap\" data-kid=\"23\">Subjects</div>\n      </div>\n      <div class=\"w-12 h-12 flex items-center justify-center rounded-2xl hover:bg-white/10 text-white/50 hover:text-white cursor-pointer group relative\" data-kid=\"24\">\n        <i class=\"fa-solid fa-chart-line text-lg\" data-kid=\"25\"></i>\n        <div class=\"absolute left-full ml-4 px-2 py-1 bg-black/80 text-[10px] rounded opacity-0 group-hover:opacity-100 pointer-events-none whitespace-nowrap\" data-kid=\"26\">Analytics</div>\n      </div>\n    </div>\n\n    <div class=\"mt-auto flex flex-col gap-4 items-center\" data-kid=\"27\">\n      <div class=\"w-12 h-12 flex items-center justify-center rounded-2xl hover:bg-white/10 text-white/50 hover:text-white cursor-pointer\" data-kid=\"28\">\n        <i class=\"fa-solid fa-gear text-lg\" data-kid=\"29\"></i>\n      </div>\n      <div class=\"relative\" data-kid=\"30\">\n        <img src=\"https://i.pravatar.cc/100?u=aero_user\" class=\"w-10 h-10 rounded-full border-2 border-[var(--color-accent)] shadow-[0_0_10px_rgba(15,255,255,0.2)]\" data-kid=\"31\">\n        <div class=\"absolute bottom-0 right-0 w-3 h-3 bg-green-500 border-2 border-[#010B13] rounded-full\" data-kid=\"32\"></div>\n      </div>\n    </div>\n  </nav>\n\n  \n  <main class=\"flex-1 max-w-[1440px] mx-auto\" data-kid=\"33\">\n    \n    <header class=\"mb-10 flex justify-between items-end gsap-reveal\" data-kid=\"34\">\n      <div data-kid=\"35\">\n        <h1 class=\"text-4xl font-heading font-extrabold tracking-tight mb-2\" data-kid=\"36\">Welcome back, <span class=\"text-[var(--color-accent)]\" data-kid=\"37\">Arsalan</span></h1>\n        <p class=\"text-white/40 font-medium\" data-kid=\"38\">Monday, 24th October 2024</p>\n      </div>\n      <div class=\"flex gap-4\" data-kid=\"39\">\n        <div class=\"glass px-6 py-3 rounded-2xl flex items-center gap-3\" data-kid=\"40\">\n          <div class=\"w-2 h-2 rounded-full bg-green-400 animate-ping\" data-kid=\"41\"></div>\n          <span class=\"text-sm font-bold uppercase tracking-widest text-white/60\" data-kid=\"42\">Live Stream</span>\n        </div>\n      </div>\n    </header>\n\n    \n    <div class=\"dashboard-grid\" data-kid=\"43\">\n      \n      \n      <section class=\"glass col-span-8 p-8 rounded-[32px] flex flex-col gsap-reveal bento-card relative overflow-hidden\" data-kid=\"44\">\n        <div class=\"card-overlay\" data-kid=\"45\"></div>\n        <div class=\"flex justify-between items-center mb-8 relative z-10\" data-kid=\"46\">\n          <h2 class=\"text-xl font-heading font-extrabold flex items-center gap-3\" data-kid=\"47\">\n             <i class=\"fa-solid fa-bolt-lightning text-[var(--color-accent)]\" data-kid=\"48\"></i>\n             Ongoing & Upcoming\n          </h2>\n          <button class=\"text-xs font-extrabold text-[var(--color-accent)] uppercase tracking-widest hover:brightness-125\" data-kid=\"49\">Full Schedule</button>\n        </div>\n        \n        <div class=\"flex gap-6 overflow-x-auto pb-4 no-scrollbar relative z-10\" data-kid=\"50\">\n          \n          <div class=\"min-w-[300px] bg-white/5 border border-white/10 p-6 rounded-[24px] hover:border-[var(--color-accent)]/40 group relative overflow-hidden\" data-kid=\"51\">\n            <div class=\"absolute top-0 right-0 p-4\" data-kid=\"52\">\n              <span class=\"px-2 py-0.5 bg-[var(--color-accent)]/20 text-[var(--color-accent)] text-[9px] font-black rounded uppercase tracking-tighter\" data-kid=\"53\">Current</span>\n            </div>\n            <div class=\"text-[10px] text-white/30 font-bold uppercase tracking-widest mb-4\" data-kid=\"54\">09:00 - 10:30 AM</div>\n            <h3 class=\"text-xl font-heading font-extrabold mb-1 group-hover:text-[var(--color-accent)]\" data-kid=\"55\">Advanced Quantum Physics</h3>\n            <p class=\"text-sm text-white/40 mb-8\" data-kid=\"56\">Section A • Room 402</p>\n            <div class=\"flex items-center gap-3 mt-auto\" data-kid=\"57\">\n              <img src=\"https://i.pravatar.cc/100?u=prof1\" class=\"w-7 h-7 rounded-full ring-1 ring-white/20\" data-kid=\"58\">\n              <div data-kid=\"59\">\n                <span class=\"block text-xs font-bold text-white/80\" data-kid=\"60\">Prof. Sarah Jenkins</span>\n                <span class=\"block text-[10px] text-white/30\" data-kid=\"61\">Theoretical Physics Dept.</span>\n              </div>\n            </div>\n          </div>\n          \n          \n          <div class=\"min-w-[300px] bg-white/5 border border-white/10 p-6 rounded-[24px] hover:border-purple-500/40 group relative overflow-hidden\" data-kid=\"62\">\n             <div class=\"absolute top-0 right-0 p-4\" data-kid=\"63\">\n              <span class=\"px-2 py-0.5 bg-purple-500/20 text-purple-400 text-[9px] font-black rounded uppercase tracking-tighter\" data-kid=\"64\">Up Next</span>\n            </div>\n            <div class=\"text-[10px] text-white/30 font-bold uppercase tracking-widest mb-4\" data-kid=\"65\">11:00 - 12:30 PM</div>\n            <h3 class=\"text-xl font-heading font-extrabold mb-1 group-hover:text-purple-400\" data-kid=\"66\">Distributed Systems</h3>\n            <p class=\"text-sm text-white/40 mb-8\" data-kid=\"67\">Section B • Lab 102</p>\n            <div class=\"flex items-center gap-3 mt-auto\" data-kid=\"68\">\n              <img src=\"https://i.pravatar.cc/100?u=prof2\" class=\"w-7 h-7 rounded-full ring-1 ring-white/20\" data-kid=\"69\">\n              <div data-kid=\"70\">\n                <span class=\"block text-xs font-bold text-white/80\" data-kid=\"71\">Dr. Alan Turing</span>\n                <span class=\"block text-[10px] text-white/30\" data-kid=\"72\">Computer Science Dept.</span>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"min-w-[300px] bg-white/5 border border-white/10 p-6 rounded-[24px] opacity-40 hover:opacity-100 group relative overflow-hidden\" data-kid=\"73\">\n            <div class=\"text-[10px] text-white/30 font-bold uppercase tracking-widest mb-4\" data-kid=\"74\">02:00 - 03:30 PM</div>\n            <h3 class=\"text-xl font-heading font-extrabold mb-1\" data-kid=\"75\">Human Interface</h3>\n            <p class=\"text-sm text-white/40 mb-8\" data-kid=\"76\">Section C • Auditorium</p>\n            <div class=\"flex items-center gap-3 mt-auto\" data-kid=\"77\">\n              <img src=\"https://i.pravatar.cc/100?u=prof3\" class=\"w-7 h-7 rounded-full ring-1 ring-white/20\" data-kid=\"78\">\n              <span class=\"text-xs font-bold text-white/60\" data-kid=\"79\">Prof. Grace Hopper</span>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      \n      <section class=\"glass col-span-4 p-8 rounded-[32px] flex flex-col items-center justify-center gsap-reveal bento-card relative overflow-hidden\" data-kid=\"80\">\n         <div class=\"card-overlay\" data-kid=\"81\"></div>\n         <h2 class=\"text-xl font-heading font-extrabold mb-8 self-start relative z-10\" data-kid=\"82\">Engagement</h2>\n         <div class=\"attendance-ring mb-6 relative z-10\" data-kid=\"83\">\n            <div class=\"inner-text\" data-kid=\"84\">\n               <div class=\"text-5xl font-heading font-black text-[var(--color-accent)] drop-shadow-[0_0_15px_rgba(15,255,255,0.4)]\" data-kid=\"85\">88%</div>\n               <div class=\"text-[10px] font-black text-white/30 uppercase tracking-[0.2em] mt-1\" data-kid=\"86\">Consistency</div>\n            </div>\n         </div>\n         <div class=\"text-center relative z-10\" data-kid=\"87\">\n           <p class=\"text-white/40 text-sm font-medium leading-relaxed\" data-kid=\"88\">Top 5% of your cohort.</p>\n           <div class=\"flex gap-1 justify-center mt-4\" data-kid=\"89\">\n              <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]\" data-kid=\"90\"></div>\n              <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]\" data-kid=\"91\"></div>\n              <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]\" data-kid=\"92\"></div>\n              <div class=\"w-1.5 h-1.5 rounded-full bg-white/10\" data-kid=\"93\"></div>\n              <div class=\"w-1.5 h-1.5 rounded-full bg-white/10\" data-kid=\"94\"></div>\n           </div>\n         </div>\n      </section>\n\n      \n      <section class=\"glass col-span-4 p-8 rounded-[32px] gsap-reveal bento-card relative overflow-hidden\" data-kid=\"95\">\n        <div class=\"card-overlay\" data-kid=\"96\"></div>\n        <div class=\"flex justify-between items-center mb-8 relative z-10\" data-kid=\"97\">\n          <h2 class=\"text-xl font-heading font-extrabold\" data-kid=\"98\">Pulse Feed</h2>\n          <div class=\"pulse-dot\" data-kid=\"99\"></div>\n        </div>\n        <div class=\"space-y-4 relative z-10\" data-kid=\"100\">\n          \n          <div class=\"p-5 bg-white/5 border border-white/5 rounded-[20px] relative group cursor-pointer overflow-hidden hover:bg-white/10 transition-colors\" data-kid=\"101\">\n             <div class=\"flex items-center gap-3 mb-2\" data-kid=\"102\">\n                <div class=\"w-2 h-2 rounded-full bg-[var(--color-accent)]\" data-kid=\"103\"></div>\n                <p class=\"text-sm font-bold\" data-kid=\"104\">Timetable Drift</p>\n             </div>\n             <p class=\"text-xs text-white/40 leading-relaxed mb-3\" data-kid=\"105\">Grade 12 Physics lab has been rescheduled to Friday afternoon due to maintenance.</p>\n             <span class=\"text-[9px] font-bold text-white/20 uppercase tracking-widest\" data-kid=\"106\">Just now</span>\n          </div>\n          \n          <div class=\"p-5 bg-white/5 border border-white/5 rounded-[20px] relative group cursor-pointer overflow-hidden hover:bg-white/10 transition-colors\" data-kid=\"107\">\n             <div class=\"flex items-center gap-3 mb-2\" data-kid=\"108\">\n                <div class=\"w-2 h-2 rounded-full bg-purple-500\" data-kid=\"109\"></div>\n                <p class=\"text-sm font-bold\" data-kid=\"110\">Material Drop</p>\n             </div>\n             <p class=\"text-xs text-white/40 leading-relaxed mb-3\" data-kid=\"111\">Dr. Alan Turing uploaded \"Scalability Patterns\" for Distributed Systems.</p>\n             <span class=\"text-[9px] font-bold text-white/20 uppercase tracking-widest\" data-kid=\"112\">42m ago</span>\n          </div>\n        </div>\n      </section>\n\n      \n      <section class=\"glass col-span-8 p-8 rounded-[32px] gsap-reveal bento-card relative overflow-hidden\" data-kid=\"113\">\n        <div class=\"card-overlay\" data-kid=\"114\"></div>\n        <h2 class=\"text-xl font-heading font-extrabold mb-8 relative z-10\" data-kid=\"115\">Accelerate</h2>\n        <div class=\"grid grid-cols-2 gap-6 relative z-10\" data-kid=\"116\">\n           \n           <div class=\"flex items-center gap-6 p-6 bg-white/5 border border-white/5 rounded-[24px] hover:bg-[var(--color-accent)]/10 hover:border-[var(--color-accent)]/30 transition-all cursor-pointer group\" data-kid=\"117\">\n              <div class=\"w-14 h-14 rounded-2xl bg-[var(--color-accent)]/10 flex items-center justify-center text-[var(--color-accent)] group-hover:scale-110 transition-transform shadow-[0_0_20px_rgba(15,255,255,0.1)]\" data-kid=\"118\">\n                <i class=\"fa-solid fa-file-signature text-2xl\" data-kid=\"119\"></i>\n              </div>\n              <div data-kid=\"120\">\n                <h3 class=\"font-bold text-lg mb-0.5\" data-kid=\"121\">Leave Terminal</h3>\n                <p class=\"text-xs text-white/40 uppercase tracking-wide\" data-kid=\"122\">Quick Approval System</p>\n              </div>\n           </div>\n           \n           <div class=\"flex items-center gap-6 p-6 bg-white/5 border border-white/5 rounded-[24px] hover:bg-purple-500/10 hover:border-purple-500/30 transition-all cursor-pointer group\" data-kid=\"123\">\n              <div class=\"w-14 h-14 rounded-2xl bg-purple-500/10 flex items-center justify-center text-purple-400 group-hover:scale-110 transition-transform shadow-[0_0_20px_rgba(168,85,247,0.1)]\" data-kid=\"124\">\n                <i class=\"fa-solid fa-graduation-cap text-2xl\" data-kid=\"125\"></i>\n              </div>\n              <div data-kid=\"126\">\n                <h3 class=\"font-bold text-lg mb-0.5\" data-kid=\"127\">Performance</h3>\n                <p class=\"text-xs text-white/40 uppercase tracking-wide\" data-kid=\"128\">Semester 1 Analytics</p>\n              </div>\n           </div>\n           \n           <div class=\"flex items-center gap-6 p-6 bg-white/5 border border-white/5 rounded-[24px] hover:bg-blue-500/10 hover:border-blue-500/30 transition-all cursor-pointer group\" data-kid=\"129\">\n              <div class=\"w-14 h-14 rounded-2xl bg-blue-500/10 flex items-center justify-center text-blue-400 group-hover:scale-110 transition-transform shadow-[0_0_20px_rgba(59,130,246,0.1)]\" data-kid=\"130\">\n                <i class=\"fa-solid fa-user-group text-2xl\" data-kid=\"131\"></i>\n              </div>\n              <div data-kid=\"132\">\n                <h3 class=\"font-bold text-lg mb-0.5\" data-kid=\"133\">Faculty Connect</h3>\n                <p class=\"text-xs text-white/40 uppercase tracking-wide\" data-kid=\"134\">Instant Messaging</p>\n              </div>\n           </div>\n           \n           <div class=\"flex items-center gap-6 p-6 bg-white/5 border border-white/5 rounded-[24px] hover:bg-emerald-500/10 hover:border-emerald-500/30 transition-all cursor-pointer group\" data-kid=\"135\">\n              <div class=\"w-14 h-14 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 group-hover:scale-110 transition-transform shadow-[0_0_20px_rgba(16,185,129,0.1)]\" data-kid=\"136\">\n                <i class=\"fa-solid fa-calendar-check text-2xl\" data-kid=\"137\"></i>\n              </div>\n              <div data-kid=\"138\">\n                <h3 class=\"font-bold text-lg mb-0.5\" data-kid=\"139\">Sync Assets</h3>\n                <p class=\"text-xs text-white/40 uppercase tracking-wide\" data-kid=\"140\">Calendar Integration</p>\n              </div>\n           </div>\n        </div>\n      </section>\n\n    </div>\n  </main>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"141\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"142\"></script>\n<script data-kid=\"143\">gsap.registerPlugin(ScrollTrigger);</script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js\" data-kid=\"144\"></script>\n<script type=\"module\" data-kid=\"145\">\n  import { animate, scroll, hover } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\";\n  import Lenis from \"https://esm.sh/lenis@1\";\n\n  // Initialize Lenis for smooth scroll\n  const lenis = new Lenis();\n  function raf(time) {\n    lenis.raf(time);\n    requestAnimationFrame(raf);\n  }\n  requestAnimationFrame(raf);\n\n  // Velocity Distortion Effect\n  const meshBg = document.getElementById('mesh-bg');\n  lenis.on('scroll', (e) => {\n    const velocity = Math.abs(e.velocity);\n    const skew = Math.min(velocity * 0.08, 3);\n    const blur = 80 + Math.min(velocity * 0.15, 30);\n    gsap.to(meshBg, { \n      skewY: skew, \n      filter: `blur(${blur}px)`, \n      duration: 0.6,\n      overwrite: \"auto\" \n    });\n  });\n\n  // GSAP Entrance\n  const entrance = gsap.timeline();\n  \n  entrance.from(\".nav-rail\", {\n    x: -120,\n    opacity: 0,\n    duration: 1.5,\n    ease: \"expo.out\"\n  });\n\n  entrance.to(\".gsap-reveal\", {\n    opacity: 1,\n    y: 0,\n    duration: 1.2,\n    stagger: 0.15,\n    ease: \"power4.out\",\n    onStart: () => {\n      gsap.set(\".gsap-reveal\", { y: 40 });\n    }\n  }, \"-=1.2\");\n\n  // Ambient Drift (GSAP Looping)\n  gsap.to(\".orb-1\", { x: \"15vw\", y: \"10vh\", duration: 25, repeat: -1, yoyo: true, ease: \"sine.inOut\" });\n  gsap.to(\".orb-2\", { x: \"-10vw\", y: \"-15vh\", duration: 20, repeat: -1, yoyo: true, ease: \"sine.inOut\" });\n  gsap.to(\".orb-3\", { x: \"-5vw\", y: \"12vh\", duration: 18, repeat: -1, yoyo: true, ease: \"sine.inOut\" });\n\n  // Motion Hover Glows\n  const bentoCards = document.querySelectorAll(\".bento-card\");\n  bentoCards.forEach(card => {\n    const overlay = card.querySelector(\".card-overlay\");\n    hover(card, (element) => {\n      animate(overlay, { opacity: 1 }, { duration: 0.6 });\n      animate(element, { \n        boxShadow: \"0 0 50px rgba(15, 255, 255, 0.15)\",\n        borderColor: \"rgba(15, 255, 255, 0.4)\"\n      }, { duration: 0.4 });\n      return () => {\n        animate(overlay, { opacity: 0 }, { duration: 0.6 });\n        animate(element, { \n          boxShadow: \"0 0 0px rgba(15, 255, 255, 0)\",\n          borderColor: \"rgba(15, 255, 255, 0.2)\"\n        }, { duration: 0.4 });\n      };\n    });\n  });\n\n  // Theme Toggle Logic\n  const toggle = document.getElementById('theme-toggle');\n  const themeIcon = document.getElementById('theme-icon');\n  let isDark = true;\n\n  toggle.addEventListener('click', () => {\n    isDark = !isDark;\n    const tl = gsap.timeline();\n    \n    if (!isDark) {\n      tl.to(\":root\", {\n        \"--color-bg\": \"#F0F4F8\",\n        \"--glass-bg\": \"rgba(255, 255, 255, 0.6)\",\n        \"--glass-border\": \"rgba(0, 0, 0, 0.08)\",\n        duration: 0.8,\n        ease: \"power2.inOut\"\n      });\n      tl.to(\"body\", { color: \"#0F172A\", duration: 0.5 }, 0);\n      tl.to(\".orb\", { opacity: 0.2, duration: 0.5 }, 0);\n      \n      themeIcon.innerHTML = '<i class=\"fa-solid fa-sun text-xs\"></i>';\n      toggle.querySelector('span').textContent = 'Light Mode';\n    } else {\n      tl.to(\":root\", {\n        \"--color-bg\": \"#010B13\",\n        \"--glass-bg\": \"rgba(255, 255, 255, 0.05)\",\n        \"--glass-border\": \"rgba(15, 255, 255, 0.2)\",\n        duration: 0.8,\n        ease: \"power2.inOut\"\n      });\n      tl.to(\"body\", { color: \"white\", duration: 0.5 }, 0);\n      tl.to(\".orb\", { opacity: 0.5, duration: 0.5 }, 0);\n\n      themeIcon.innerHTML = '<i class=\"fa-solid fa-moon text-xs\"></i>';\n      toggle.querySelector('span').textContent = 'Dark Mode';\n    }\n    \n    animate(themeIcon, { rotate: isDark ? 0 : 360, scale: [0.7, 1] }, { duration: 0.4, ease: \"backOut\" });\n  });\n\n</script>\n",
