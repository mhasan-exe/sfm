rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------
    // Helpers
    // ---------------------------------------------------------------
    //
    // CRITICAL: the "only @akesp.net accounts" restriction used to live
    // ENTIRELY in client code (AuthService.isAllowedEmail), which signs
    // the user out and throws an error AFTER Firebase Auth has already
    // issued them a fully valid session. Firebase Auth itself places no
    // domain restriction on Google sign-in, and these rules previously
    // only checked `request.auth != null` — meaning literally any Google
    // account on the internet could authenticate and then read/write
    // every collection gated by isSignedIn(), simply by not using the
    // app's own client (a raw SDK call, a patched APK, or just calling
    // Firestore directly with the obtained ID token all skip the
    // sign-out-after-the-fact check entirely). The client check is still
    // worth keeping for UX, but it is not a security boundary — only a
    // rule is. Enforcing the domain check inside isSignedIn() itself
    // means every one of the ~26 places in this file that call
    // isSignedIn() (directly or via isAdmin()/isOwner()) gets the fix
    // for free, with no other line in this file needing to change.
    //
    // Keep this allow-list in sync with AuthService.isAllowedEmail in
    // the Flutter app if it's ever updated.
    function isAllowedDomain() {
      return request.auth.token.email != null &&
        (request.auth.token.email.matches('.*@akesp[.]net$') ||
         request.auth.token.email == '2817783@students.akesp.net');
    }

    function isSignedIn() {
      return request.auth != null && isAllowedDomain();
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ---------------------------------------------------------------
    // admins — who is an admin. Anyone signed in can check membership
    // (the app needs this for its own isAdmin() UI check), but only an
    // existing admin can grant/revoke admin access.
    // ---------------------------------------------------------------
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // users — every signed-in user can read the directory (Profiles
    // screen needs to list every teacher). Users may update their own
    // doc; admins can update anyone's (e.g. workload resets).
    //
    // CRITICAL: `allow update: if isOwner(userId) || isAdmin();` placed
    // no restriction on WHICH fields a self-update could touch. The app
    // only ever self-edits name/bio/photoUrl (see
    // UserService.updateUserProfile) plus a bounded ±1 step on
    // `fixtureUnits` as a side effect of claiming/releasing a fixture
    // (see FixtureService._safeAdjustFixtureUnits — every real call site
    // passes exactly +1 or -1, never anything else) — but the rule let a
    // user write a raw update to their own doc setting `fixtureUnits` to
    // a large negative number in one shot (instantly "earning" unlimited
    // fixture-claim quota, since every quota check reads this same
    // field), or `role`/`isAdmin` to something privileged. Self-updates
    // are now restricted to those exact fields, with `fixtureUnits`
    // additionally bounded to a single ±1 step that never goes negative;
    // anything else (a bigger jump, a negative result, role, isAdmin)
    // requires isAdmin(). Note: this is still a workaround for the
    // client writing a quota counter directly at all — the durable fix
    // is moving claim/release into a trusted Cloud Function so clients
    // never write this field themselves; flagging that as a follow-up,
    // not implementing it here since there's no functions/ in this repo.
    // ---------------------------------------------------------------
    function selfEditableUserFields() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['name', 'bio', 'photoUrl', 'updatedAt', 'fixtureUnits']) &&
        (!affected.hasAny(['fixtureUnits']) ||
          (request.resource.data.fixtureUnits >= 0 &&
           (request.resource.data.fixtureUnits - resource.data.fixtureUnits == 1 ||
            request.resource.data.fixtureUnits - resource.data.fixtureUnits == -1)));
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && selfEditableUserFields());
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------
    // classes — every signed-in user can read (teachers need to see
    // their own class assignments); only admins manage classes.
    // ---------------------------------------------------------------
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /time_profiles/{profileId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // weekly_timetables — every signed-in user reads (teachers view
    // their own schedule, derived client-side from the full
    // collection); only admins write (manual edits + generation).
    // ---------------------------------------------------------------
    match /weekly_timetables/{slotId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // timetable_exceptions — REPLACES daily_timetables. Sparse per-date
    // deviations (leave vacancies, same-day exchanges, admin overrides,
    // fixture cover). Every signed-in user reads (teachers need to see
    // today's effective schedule, not just the weekly pattern). Write
    // is NOT admin-only on purpose: a teacher's own same-day exchange
    // and a teacher claiming/releasing a fixture both write here
    // directly from the client, same trust model already used below
    // for `fixtures` (client-side logic decides what's a legal write,
    // not the rules). Admin-driven writes (leave approval, regenerate,
    // restore preset) are covered by isSignedIn() too since admins are
    // signed in.
    // ---------------------------------------------------------------
    match /timetable_exceptions/{exceptionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ---------------------------------------------------------------
    // daily_timetables — DEPRECATED. The app no longer reads or writes
    // this collection anywhere (replaced by timetable_exceptions
    // above). Left read-only-ish here (admin-write) purely so nothing
    // breaks if any old data is still sitting in it; safe to delete
    // this block and the collection itself whenever convenient.
    // ---------------------------------------------------------------
    match /daily_timetables/{slotId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // leave_requests — admins need explicit read access for the "all
    // pending requests" query (a rule that only matched
    // resource.data.teacherId == auth.uid would reject that whole
    // query, not just filter it).
    //
    // CRITICAL: the update rule used to only check the EXISTING status
    // was 'pending' before letting the owner update — it never checked
    // what the owner was changing status TO. A teacher could update
    // their own pending request directly (bypassing LeaveService
    // entirely — rules are the real boundary, not app code) and set
    // status: 'approved' themselves. Now the owner may only move their
    // own request to 'pending' (a no-op edit) or 'cancelled' — moving
    // to 'approved' or 'rejected' requires isAdmin().
    // ---------------------------------------------------------------
    match /leave_requests/{requestId} {
      allow read: if isAdmin() || isOwner(resource.data.teacherId);
      allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid;
      allow update: if isAdmin() ||
        (isOwner(resource.data.teacherId) &&
         resource.data.status == 'pending' &&
         request.resource.data.status in ['pending', 'cancelled']);
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------
    // notifications — recipients read/mark their own as read.
    //
    // FIX: `allow create: if isSignedIn();` had no validation at all —
    // any signed-in user could create a notification addressed to ANY
    // other user, with any title/body/type, including types like
    // 'leaveApproved'/'leaveRejected' that imply admin authority (the
    // recipient has no way to tell it wasn't really from an admin). Now
    // requires: `senderId` truthfully matches the caller (so the field
    // can be trusted for display/audit instead of being a client claim),
    // the recipient is a real user, title/body are reasonably bounded
    // strings, and the two admin-authority types are gated to isAdmin().
    // `notifyAdmins()` legitimately fires from ordinary teacher actions
    // (submitting leave, claiming a fixture) — its 'adminNotification'
    // type is intentionally NOT restricted to admin senders here.
    // ---------------------------------------------------------------
    function isValidNotificationCreate() {
      let d = request.resource.data;
      return d.senderId == request.auth.uid &&
        d.userId is string && d.userId.size() > 0 &&
        exists(/databases/$(database)/documents/users/$(d.userId)) &&
        d.title is string && d.title.size() <= 300 &&
        d.body is string && d.body.size() <= 1000 &&
        (!(d.type in ['NotificationType.leaveApproved', 'NotificationType.leaveRejected']) || isAdmin());
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && isValidNotificationCreate();
      allow update: if isAdmin() ||
        (isOwner(resource.data.userId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']));
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------
    // fixtures — every signed-in user reads (marketplace); claiming a
    // fixture is a teacher updating their own claim, everything else
    // (creating/expiring fixtures) is admin-driven.
    //
    // NOTE: `allow update: if isAdmin() || isSignedIn()` has no
    // ownership check — any signed-in teacher can update ANY fixture
    // document, not just one they're claiming. The app's client code
    // is well-behaved, but the rule itself doesn't enforce that.
    // Tightening this to something like
    //   allow update: if isAdmin() ||
    //     (isSignedIn() && request.resource.data.claimedBy == request.auth.uid) ||
    //     (isSignedIn() && resource.data.status == 'available')
    // would require auditing every client write path that touches
    // fixtures first, so left as-is here — flagging it, not changing
    // it, since narrowing it blind risks breaking a legitimate flow.
    // ---------------------------------------------------------------
    match /fixtures/{fixtureId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || isSignedIn();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------
    // admin_configs — system-wide settings. Every signed-in user may
    // need to read it (e.g. the same-day leave cutoff check happens
    // from the teacher's own leave-submission flow); only admins write.
    // ---------------------------------------------------------------
    match /admin_configs/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // audit_logs — write-only from the app's perspective (any signed-in
    // action can log itself); only admins read the log back.
    // ---------------------------------------------------------------
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ---- Break duty roster ----
    match /break_duties/{dutyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---- Admin announcements / scheduled events ----
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Each teacher can create/read their OWN acknowledgement record only.
    // Doc ID convention used by the app: "{announcementId}_{uid}".
    match /announcement_acks/{ackId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ---- Reminder de-duplication ledger (class/break-duty/event reminders) ----
    // Low-sensitivity — just prevents double-sending a reminder.
    match /reminder_log/{logId} {
      allow read, write: if isSignedIn();
    }

    // ---- Timetable presets (save/load/rollback whole-class snapshots) ----
    // Current implementation stores each preset's slot list as an array
    // field on the preset document itself (not a subcollection), so the
    // top-level rule below already covers reads/writes of that data; the
    // nested `slots/{slotId}` rule is kept in case a future version moves
    // to a subcollection-per-slot layout, but isn't currently exercised.
    match /timetable_presets/{presetId} {
      allow read: if isAdmin();
      allow write: if isAdmin();

      match /slots/{slotId} {
        allow read: if isAdmin();
        allow write: if isAdmin();
      }
    }
  }
}
